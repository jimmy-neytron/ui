{
    "name":  "@neytron/compact-ui",
    "version":  "0.3.0",
    "description":  "Lightweight and customizable Vue 3 UI component library",
    "type":  "module",
    "license":  "MIT",
    "author":  "jimmy-neytron",
    "repository":  {
                       "type":  "git",
                       "url":  "git+https://github.com/jimmy-neytron/ui.git"
                   },
    "homepage":  "https://github.com/jimmy-neytron/ui#readme",
    "bugs":  {
                 "url":  "https://github.com/jimmy-neytron/ui/issues"
             },
    "engines":  {
                    "node":  "\u003e=24"
                },
    "files":  [
                  "dist",
                  "README.md",
                  "CHANGELOG.md",
                  "LICENSE"
              ],
    "main":  "./dist/index.js",
    "module":  "./dist/index.js",
    "types":  "./dist/index.d.ts",
    "exports":  {
                    ".":  {
                              "types":  "./dist/index.d.ts",
                              "import":  "./dist/index.js"
                          },
                    "./button":  {
                                     "types":  "./dist/components/button/index.d.ts",
                                     "import":  "./dist/components/button/index.js"
                                 },
                    "./input":  {
                                    "types":  "./dist/components/input/index.d.ts",
                                    "import":  "./dist/components/input/index.js"
                                },
                    "./textarea":  {
                                       "types":  "./dist/components/textarea/index.d.ts",
                                       "import":  "./dist/components/textarea/index.js"
                                   },
                    "./select":  {
                                     "types":  "./dist/components/select/index.d.ts",
                                     "import":  "./dist/components/select/index.js"
                                 },
                    "./checkbox":  {
                                       "types":  "./dist/components/checkbox/index.d.ts",
                                       "import":  "./dist/components/checkbox/index.js"
                                   },
                    "./radio":  {
                                    "types":  "./dist/components/radio/index.d.ts",
                                    "import":  "./dist/components/radio/index.js"
                                },
                    "./switch":  {
                                     "types":  "./dist/components/switch/index.d.ts",
                                     "import":  "./dist/components/switch/index.js"
                                 },
                    "./badge":  {
                                    "types":  "./dist/components/badge/index.d.ts",
                                    "import":  "./dist/components/badge/index.js"
                                },
                    "./styles.css":  "./dist/styles.css",
                    "./package.json":  "./package.json",
                    "./alert":  {
                                    "types":  "./dist/components/alert/index.d.ts",
                                    "import":  "./dist/components/alert/index.js"
                                },
                    "./card":  {
                                   "types":  "./dist/components/card/index.d.ts",
                                   "import":  "./dist/components/card/index.js"
                               },
                    "./progress":  {
                                       "types":  "./dist/components/progress/index.d.ts",
                                       "import":  "./dist/components/progress/index.js"
                                   },
                    "./spinner":  {
                                      "types":  "./dist/components/spinner/index.d.ts",
                                      "import":  "./dist/components/spinner/index.js"
                                  },
                    "./accordion":  {
                                        "types":  "./dist/components/accordion/index.d.ts",
                                        "import":  "./dist/components/accordion/index.js"
                                    },
                    "./avatar":  {
                                     "types":  "./dist/components/avatar/index.d.ts",
                                     "import":  "./dist/components/avatar/index.js"
                                 },
                    "./breadcrumb":  {
                                         "types":  "./dist/components/breadcrumb/index.d.ts",
                                         "import":  "./dist/components/breadcrumb/index.js"
                                     },
                    "./config-provider":  {
                                              "types":  "./dist/components/config-provider/index.d.ts",
                                              "import":  "./dist/components/config-provider/index.js"
                                          },
                    "./dialog":  {
                                     "types":  "./dist/components/dialog/index.d.ts",
                                     "import":  "./dist/components/dialog/index.js"
                                 },
                    "./divider":  {
                                      "types":  "./dist/components/divider/index.d.ts",
                                      "import":  "./dist/components/divider/index.js"
                                  },
                    "./dropdown-menu":  {
                                            "types":  "./dist/components/dropdown-menu/index.d.ts",
                                            "import":  "./dist/components/dropdown-menu/index.js"
                                        },
                    "./empty-state":  {
                                          "types":  "./dist/components/empty-state/index.d.ts",
                                          "import":  "./dist/components/empty-state/index.js"
                                      },
                    "./pagination":  {
                                         "types":  "./dist/components/pagination/index.d.ts",
                                         "import":  "./dist/components/pagination/index.js"
                                     },
                    "./popover":  {
                                      "types":  "./dist/components/popover/index.d.ts",
                                      "import":  "./dist/components/popover/index.js"
                                  },
                    "./skeleton":  {
                                       "types":  "./dist/components/skeleton/index.d.ts",
                                       "import":  "./dist/components/skeleton/index.js"
                                   },
                    "./tabs":  {
                                   "types":  "./dist/components/tabs/index.d.ts",
                                   "import":  "./dist/components/tabs/index.js"
                               },
                    "./toast":  {
                                    "types":  "./dist/components/toast/index.d.ts",
                                    "import":  "./dist/components/toast/index.js"
                                },
                    "./tooltip":  {
                                      "types":  "./dist/components/tooltip/index.d.ts",
                                      "import":  "./dist/components/tooltip/index.js"
                                  }
                },
    "sideEffects":  [
                        "**/*.css"
                    ],
    "publishConfig":  {
                          "access":  "public",
                          "registry":  "https://registry.npmjs.org/"
                      },
    "peerDependencies":  {
                             "vue":  "\u003e=3.5.0 \u003c4"
                         },
    "scripts":  {
                    "dev":  "vite --config vite.playground.config.ts",
                    "build":  "node scripts/build.mjs",
                    "build:js":  "vite build",
                    "build:types":  "vue-tsc --project tsconfig.build.json --declaration --emitDeclarationOnly",
                    "playground:build":  "vite build --config vite.playground.config.ts",
                    "playground:preview":  "vite preview --config vite.playground.config.ts",
                    "docs:dev":  "npm --prefix docs run dev",
                    "docs:build":  "npm --prefix docs run build",
                    "docs:preview":  "npm --prefix docs run preview",
                    "typecheck":  "vue-tsc --noEmit",
                    "test":  "vitest run",
                    "test:watch":  "vitest",
                    "test:coverage":  "vitest run --coverage",
                    "lint":  "eslint .",
                    "check:size":  "node scripts/check-bundle-size.mjs",
                    "check:package":  "node scripts/validate-package.mjs",
                    "test:package":  "node scripts/test-package.mjs",
                    "pack":  "npm run build \u0026\u0026 npm pack --pack-destination .artifacts",
                    "pack:dry":  "npm run build \u0026\u0026 npm pack --dry-run",
                    "check":  "npm run lint \u0026\u0026 npm run check:rtl \u0026\u0026 npm run typecheck \u0026\u0026 npm run test:coverage \u0026\u0026 npm run build \u0026\u0026 npm run check:size \u0026\u0026 npm run check:package",
                    "prepublishOnly":  "npm run check \u0026\u0026 npm run test:package \u0026\u0026 npm run pack:dry",
                    "check:rtl":  "node scripts/check-rtl.mjs"
                },
    "devDependencies":  {
                            "@eslint/js":  "^9.31.0",
                            "@types/node":  "^24.0.0",
                            "@vitejs/plugin-vue":  "^6.0.1",
                            "@vitest/coverage-v8":  "^3.2.4",
                            "@vue/test-utils":  "^2.4.6",
                            "eslint":  "^9.31.0",
                            "eslint-plugin-vue":  "^10.3.0",
                            "globals":  "^16.3.0",
                            "jsdom":  "^26.1.0",
                            "typescript":  "^5.8.3",
                            "typescript-eslint":  "^8.38.0",
                            "vite":  "^7.0.6",
                            "vitest":  "^3.2.4",
                            "vue":  "3.5.40",
                            "vue-tsc":  "^3.0.4"
                        }
}
