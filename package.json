{
  "name": "@neytron/compact-ui",
  "version": "0.1.1",
  "description": "Lightweight and customizable Vue 3 UI component library",
  "type": "module",
  "license": "MIT",
  "author": "jimmy-neytron",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jimmy-neytron/ui.git"
  },
  "homepage": "https://github.com/jimmy-neytron/ui#readme",
  "bugs": {
    "url": "https://github.com/jimmy-neytron/ui/issues"
  },
  "engines": {
    "node": ">=24"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./button": {
      "types": "./dist/components/button/index.d.ts",
      "import": "./dist/components/button/index.js"
    },
    "./input": {
      "types": "./dist/components/input/index.d.ts",
      "import": "./dist/components/input/index.js"
    },
    "./textarea": {
      "types": "./dist/components/textarea/index.d.ts",
      "import": "./dist/components/textarea/index.js"
    },
    "./select": {
      "types": "./dist/components/select/index.d.ts",
      "import": "./dist/components/select/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "vue": ">=3.5.0 <4"
  },
  "scripts": {
    "dev": "vite --config vite.playground.config.ts",
    "build": "node scripts/build.mjs",
    "build:js": "vite build",
    "build:types": "vue-tsc --project tsconfig.build.json --declaration --emitDeclarationOnly",
    "playground:build": "vite build --config vite.playground.config.ts",
    "playground:preview": "vite preview --config vite.playground.config.ts",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "check:size": "node scripts/check-bundle-size.mjs",
    "check:package": "node scripts/validate-package.mjs",
    "test:package": "node scripts/test-package.mjs",
    "pack": "npm run build && npm pack --pack-destination .artifacts",
    "pack:dry": "npm run build && npm pack --dry-run",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build && npm run check:size && npm run check:package",
    "prepublishOnly": "npm run check && npm run test:package && npm run pack:dry"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/node": "^24.0.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.31.0",
    "eslint-plugin-vue": "^10.3.0",
    "globals": "^16.3.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vite": "^7.0.6",
    "vitest": "^3.2.4",
    "vue": "3.5.40",
    "vue-tsc": "^3.0.4"
  }
}
